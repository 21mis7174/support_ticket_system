# EC2 Configuration File
# Used by deploy.sh and ec2-update.sh to deploy the application to AWS EC2
# RULE EP-01: Never hardcode localhost in this file
# RULE IT-02: Ensure EC2 and your machine have the same CPU architecture (x86_64)

# ════════════════════════════════════════════════════════════════════════════════
# EC2 SSH Configuration
# ════════════════════════════════════════════════════════════════════════════════

# EC2 instance connection details
EC2_USER=ec2-user                    # Amazon Linux 2023 uses ec2-user
EC2_HOST=ec2-13-233-109-44.ap-south-1.compute.amazonaws.com  # Your EC2 public hostname
EC2_PEM=/home/uday/.aws_keys/Support_Ticket_System_Key.pem  # Path to your PEM key file

# Where to clone the project on EC2
REMOTE_PROJECT_DIR=/home/ec2-user/V12_Project

# ════════════════════════════════════════════════════════════════════════════════
# Port Configuration
# RULE EP-07: Container ports are FIXED (5000 for frontend, 5001 for backend)
# These are the HOST ports (external access). Change if needed.
# ════════════════════════════════════════════════════════════════════════════════

FRONTEND_PORT=5000
BACKEND_PORT=5001

# ════════════════════════════════════════════════════════════════════════════════
# Public Network Information
# RULE EP-04: Both PUBLIC_HOST and PUBLIC_IP needed for CORS origins
# When EC2 instance is restarted, public IP changes!
# Get current values: 
#   AWS Console → EC2 → Instances → Click your instance → Public IPv4 address/DNS
# Or: ssh EC2 "curl -s http://169.254.169.254/latest/meta-data/public-ipv4"
# ════════════════════════════════════════════════════════════════════════════════

PUBLIC_HOST=ec2-13-233-109-44.ap-south-1.compute.amazonaws.com
PUBLIC_IP=13.233.109.44

# ════════════════════════════════════════════════════════════════════════════════
# MongoDB Configuration
# RULE EP-01: These should match docker-compose.yml environment defaults
# Change passwords before first deployment!
# ════════════════════════════════════════════════════════════════════════════════

MONGO_USERNAME=mongo
MONGO_PASSWORD=mongopass  # CHANGE THIS before production!
MONGO_DB=support_tickets
MONGO_PORT=27017

# ════════════════════════════════════════════════════════════════════════════════
# Application Environment
# RULE EP-11: Timezone - set to Asia/Kolkata for IST (instead of UTC)
# RULE EP-17: APPLICATION_ENV determines behavior (dev/staging/prod)
# ════════════════════════════════════════════════════════════════════════════════

NODE_ENV=production              # Node.js environment
APPLICATION_ENV=production       # Application environment
TZ=Asia/Kolkata                  # Timezone for logs and timestamps
LOG_LEVEL=info                   # Backend logging level (info, debug, warn, error)

# ════════════════════════════════════════════════════════════════════════════════
# Security & CORS
# RULE EP-04: CORS_ALLOWED_ORIGINS must include both local and EC2 URLs
# deploy.sh will add localhost/127.0.0.1 for local development support
# ════════════════════════════════════════════════════════════════════════════════

# Additional CORS origins (one per line, comma-separated in .env)
# These are ADDED to: localhost, 127.0.0.1, PUBLIC_HOST, PUBLIC_IP
CORS_ORIGINS=${PUBLIC_HOST},${PUBLIC_IP}

# ════════════════════════════════════════════════════════════════════════════════
# Git Configuration
# Used by deploy.sh to ensure code is up-to-date
# ════════════════════════════════════════════════════════════════════════════════

GIT_REPO=https://github.com/21mis7174/support_ticket_system.git
GIT_BRANCH=main

# ════════════════════════════════════════════════════════════════════════════════
# Storage Configuration
# RULE EP-13: Paths inside container are /app/storage/* (bind mount from host)
# These are the actual host paths on EC2
# ════════════════════════════════════════════════════════════════════════════════

STORAGE_DIR=${REMOTE_PROJECT_DIR}/storage
LOGS_DIR=${STORAGE_DIR}/logs
SQLITE_DIR=${STORAGE_DIR}/sqlite
CACHE_DIR=${STORAGE_DIR}/cache
INSTRUMENTS_DIR=${STORAGE_DIR}/instruments

# ════════════════════════════════════════════════════════════════════════════════
# Advanced Configuration (usually no need to change)
# ════════════════════════════════════════════════════════════════════════════════

# Docker image names (must match docker-compose.yml)
BACKEND_IMAGE=docker-backend:latest
FRONTEND_IMAGE=docker-frontend:latest

# Temporary archive path (both local and EC2)
ARCHIVE_PATH=/tmp/v12-images.tar.gz
ARCHIVE_SIZE_MB=350  # Approximate size for progress indication

# Health check timeout
HEALTH_CHECK_TIMEOUT=30  # seconds to wait for containers to become healthy

# SSH options
SSH_OPTIONS="-o StrictHostKeyChecking=no -o ConnectTimeout=10 -o BatchMode=yes"

# ════════════════════════════════════════════════════════════════════════════════
# Deployment Notes
# ════════════════════════════════════════════════════════════════════════════════

# CHECKLIST before first deployment:
# ☐ EC2_HOST and EC2_PEM are correct (ssh -i $PEM $EC2_USER@$EC2_HOST "echo ok")
# ☐ PUBLIC_HOST and PUBLIC_IP match EC2 (check AWS Console)
# ☐ SSH security group allows port 22 from your IP
# ☐ EC2 security group allows port 5000 from 0.0.0.0/0 (frontend access)
# ☐ backend/config/api_keys.json exists and is valid JSON
# ☐ Docker images are built locally: docker images | grep docker-
# ☐ Create .env: cp .env.example .env
# ☐ Run deploy: bash deploy.sh --setup
# ☐ Wait for "Deployment complete!" message
# ☐ Test: curl http://${PUBLIC_IP}:5000/health

# AFTER EC2 REBOOT:
# ☐ Containers should auto-restart (Docker restart: unless-stopped policy)
# ☐ Verify: ssh -i $PEM $EC2_USER@$EC2_HOST "docker ps"
# ☐ If containers stopped, restart: ssh EC2 "cd $REMOTE_PROJECT_DIR/deploy/docker && docker compose up -d"

# MONITORING:
# ☐ Logs: ssh EC2 "tail -f $REMOTE_PROJECT_DIR/storage/logs/backend.log"
# ☐ Containers: ssh EC2 "docker ps && docker stats --no-stream"
# ☐ Disk: ssh EC2 "df -h && docker system df"
# ☐ Health: curl http://${PUBLIC_IP}:5000/health
